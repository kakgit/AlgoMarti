<div id="main" class="container-xxl">
    <div class="page-heading">
        <div class="row">
            <div class="col-4">
                <h3>Delta Paper Lab</h3>
            </div>
            <div class="col-4 text-center">
                <span class="badge bg-warning" id="spnGenMsg">Ready</span>
            </div>
            <div class="col-4" style="text-align: right;"></div>
        </div>
    </div>

    <div class="page-content">
        <section class="row">
            <div class="col-12 col-lg-12">
                <div class="row" style="text-align: center;">
                    <div class="col-6 col-lg-4 col-md-6">
                        <button class="badge bg-danger" onclick="fnShowDPLoginMdl();" id="btnDPTraderStatus">Trader - Invalid</button>
                    </div>
                    <div class="col-6 col-lg-4 col-md-6">
                        <button class="badge bg-danger" onclick="fnToggleDPAuto();" id="btnDPAutoStatus">Auto Trader - OFF</button>
                    </div>
                    <div class="col-6 col-lg-4 col-md-6">
                        <button class="badge bg-secondary" onclick="fnToggleDPSession();" id="btnDPSessionStatus">Session - Stopped</button>
                    </div>
                    <div class="col-12">&nbsp;</div>
                </div>
            </div>
        </section>

        <section class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Dynamic Gamma Scalping (Paper)</h4>
                    </div>
                    <div class="card-body">
                        <div class="row g-2" style="margin-bottom: 10px;">
                            <div class="col-12 col-lg-6">
                                <label class="form-label">Strategy</label>
                                <div class="input-group">
                                    <button type="button" class="btn btn-outline-success" title="Create Strategy" onclick="fnOpenDPStrategyModal();">
                                        <i class="fa fa-plus"></i>
                                    </button>
                                    <select id="ddlDPStrategies" class="form-select" onchange="fnDPSelectStrategy(this.value);">
                                        <option value="">Select Strategy</option>
                                    </select>
                                    <button type="button" class="btn btn-outline-primary" title="Update Strategy Setup" onclick="fnOpenDPStrategySetupModal();">
                                        <i class="fa fa-cog"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6" style="text-align: right;">
                                <span class="badge bg-info" id="spnDPSelectedStrategy">Selected: -</span>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-6 col-lg-2">
                                <label class="form-label">Symbol</label>
                                <select id="ddlDPSymbol" class="form-select"><option value="BTC" selected>BTC</option></select>
                            </div>
                            <div class="col-6 col-lg-2">
                                <label class="form-label">Hedge Trigger |Delta|</label>
                                <input id="txtDPHedgeDelta" type="number" class="form-control" step="0.01" value="0.10" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Neutral Band</label>
                                <input id="txtDPNeutralBand" type="number" class="form-control" step="0.01" value="0.02" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Qty (BTC)</label>
                                <input id="txtDPQtyBTC" type="number" class="form-control" step="0.01" value="1.00" />
                            </div>
                            <div class="col-6 col-lg-2">
                                <label class="form-label">Entry Gamma</label>
                                <input id="txtDPEntryGamma" type="number" class="form-control" step="0.00001" value="0.00005" />
                            </div>
                            <div class="col-6 col-lg-2">
                                <label class="form-label">Theta Cost / Day (USD)</label>
                                <input id="txtDPThetaDay" type="number" class="form-control" step="1" value="200" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Roll Dist %</label>
                                <input id="txtDPRollDistPct" type="number" class="form-control" step="0.1" value="5.0" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Roll Gamma %</label>
                                <input id="txtDPRollGammaPct" type="number" class="form-control" step="1" value="20" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Opt Brok %</label>
                                <input id="txtDPOptBrokPct" type="number" class="form-control" step="0.001" value="0.010" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Fut Brok %</label>
                                <input id="txtDPFutBrokPct" type="number" class="form-control" step="0.001" value="0.050" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Fee Mode</label>
                                <select id="ddlDPFeeMode" class="form-select">
                                    <option value="TAKER" selected>TAKER</option>
                                    <option value="MAKER">MAKER</option>
                                </select>
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Recov @</label>
                                <input id="txtDPRecoverAt" type="number" class="form-control" step="1" value="-100" />
                            </div>
                            <div class="col-6 col-lg-1">
                                <label class="form-label">Stop @</label>
                                <input id="txtDPStopAt" type="number" class="form-control" step="1" value="-300" />
                            </div>
                            <div class="col-6 col-lg-2">
                                <label class="form-label">&nbsp;</label>
                                <button class="btn btn-primary d-block w-100" onclick="fnDPOpenStraddle();">Open ATM Straddle</button>
                            </div>
                            <div class="col-6 col-lg-2">
                                <label class="form-label">&nbsp;</label>
                                <button class="btn btn-outline-danger d-block w-100" onclick="fnDPResetEngine();">Reset</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h4>Strategy Builder</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr style="text-align:center;">
                                        <th>Name</th>
                                        <th>Params</th>
                                        <th>Status</th>
                                        <th>Net</th>
                                        <th>Run</th>
                                        <th>Load</th>
                                        <th>Delete</th>
                                    </tr>
                                </thead>
                                <tbody id="tBodyDPStrategies"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-6"><h4>Engine State</h4></div>
                            <div class="col-6" style="text-align:right;">
                                <span class="badge bg-info" id="spnDPLive">BTC Spot: -</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr style="text-align:center;">
                                        <th>Status</th>
                                        <th>Spot</th>
                                        <th>Strike</th>
                                        <th>Opt Delta</th>
                                        <th>Fut Hedge</th>
                                        <th>Total Delta</th>
                                        <th>Gamma</th>
                                        <th>Rolls</th>
                                        <th>Recovery</th>
                                    </tr>
                                </thead>
                                <tbody id="tBodyDPEngine"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-3"><h4>PnL Breakdown</h4></div>
                            <div class="col-3"><span class="badge bg-secondary" id="spnDPPnl">Scalp: 0 | Option: 0 | Theta: 0 | Net: 0</span></div>
                            <div class="col-6" style="text-align:right;">
                                <button class="btn btn-sm btn-outline-primary" onclick="fnDPTickNow();">Run Tick</button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr style="text-align:center;">
                                        <th>ID</th>
                                        <th>Side</th>
                                        <th>Qty BTC</th>
                                        <th>Entry Spot</th>
                                        <th>Exit Spot</th>
                                        <th>PnL</th>
                                        <th>Reason</th>
                                    </tr>
                                </thead>
                                <tbody id="tBodyDPScalps"></tbody>
                            </table>
                        </div>
                        <hr />
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr style="text-align:center;">
                                        <th>Time</th>
                                        <th>Event</th>
                                    </tr>
                                </thead>
                                <tbody id="tBodyDPEvents"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<%- include('partials/deltaPaperSettings.ejs') %>

<div class="modal fade text-left" id="mdlDPStrategy" tabindex="-1" role="dialog" data-bs-backdrop="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-secondary">
                <h5 class="modal-title">Create Strategy</h5>
                <i class="fa fa-times" aria-hidden="true" data-bs-dismiss="modal" aria-label="Close" style="cursor: pointer;"></i>
            </div>
            <div class="modal-body">
                <label for="txtDPNewStrategyName" class="form-label">Strategy Name</label>
                <input id="txtDPNewStrategyName" type="text" class="form-control" placeholder="Ex: GS-Weekly-01" />
                <small id="spnDPStrategyMsg" class="text-muted">Name must be unique.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="fnCreateDPStrategyFromModal();">Create</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade text-left" id="mdlDPStrategySetup" tabindex="-1" role="dialog" data-bs-backdrop="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-secondary">
                <h5 class="modal-title">Strategy Setup</h5>
                <i class="fa fa-times" aria-hidden="true" data-bs-dismiss="modal" aria-label="Close" style="cursor: pointer;"></i>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                    <div class="col-12">
                        <label class="form-label">Strategy Name</label>
                        <input id="txtDPSetupStrategyName" type="text" class="form-control" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Hedge Trigger |Delta|</label>
                        <input id="txtDPSetupHedgeDelta" type="number" class="form-control" step="0.01" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Neutral Band</label>
                        <input id="txtDPSetupNeutralBand" type="number" class="form-control" step="0.01" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Qty (BTC)</label>
                        <input id="txtDPSetupQtyBTC" type="number" class="form-control" step="0.01" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Entry Gamma</label>
                        <input id="txtDPSetupEntryGamma" type="number" class="form-control" step="0.00001" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Theta / Day</label>
                        <input id="txtDPSetupThetaDay" type="number" class="form-control" step="1" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Roll Dist %</label>
                        <input id="txtDPSetupRollDistPct" type="number" class="form-control" step="0.1" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Roll Gamma %</label>
                        <input id="txtDPSetupRollGammaPct" type="number" class="form-control" step="1" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Fee Mode</label>
                        <select id="ddlDPSetupFeeMode" class="form-select">
                            <option value="TAKER">TAKER</option>
                            <option value="MAKER">MAKER</option>
                        </select>
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Opt Brok %</label>
                        <input id="txtDPSetupOptBrokPct" type="number" class="form-control" step="0.001" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Fut Brok %</label>
                        <input id="txtDPSetupFutBrokPct" type="number" class="form-control" step="0.001" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Recovery @</label>
                        <input id="txtDPSetupRecoverAt" type="number" class="form-control" step="1" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label class="form-label">Stop @</label>
                        <input id="txtDPSetupStopAt" type="number" class="form-control" step="1" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="fnApplyDPStrategySetupModal();">Update Strategy</button>
            </div>
        </div>
    </div>
</div>

<script src="/js/deltaPaperSettings.js"></script>
<script src="/js/deltaPaper.js"></script>
