                            <input type="text" id="txtRenkoSellPatterns" class="form-control form-control-sm" placeholder="RRGRR,RGRR" value="GGR,RGR" onchange="fnUpdateRenkoPatterns(this, 'sell');" style="width: 190px;" />

                            <span class="small text-muted ms-2" id="spnRenkoFeedMeta">Symbol: -</span>
                            <button class="btn btn-outline-secondary btn-sm ms-auto" type="button" onclick="fnClearRenkoFeedLog();">Clear</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="divRenkoFeedMsgs" class="renko-feed-log">
                            <div class="renko-feed-item text-muted">Feed is idle. Turn on "Delta Renko Feed" switch in Manual Trader header.</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
</div>

